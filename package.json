{
  "name": "cafe-aurora-turnos",
  "version": "1.0.0",
  "description": "API y vistas del sistema de turnos de Café Aurora, con arquitectura en capas, MongoDB Atlas (Mongoose), vistas server-side con Handlebars y tiempo real con Socket.io.",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "node --test"
  },
  "keywords": [
    "nodejs",
    "esm",
    "turnos",
    "reservas",
    "backend",
    "mongodb",
    "mongoose",
    "handlebars",
    "socket.io"
  ],
  "author": "mcornejov",
  "license": "ISC",
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "express-handlebars": "^9.0.1",
    "mongoose": "^8.9.5",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "mongodb-memory-server": "^11.2.0",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2"
  }
}
